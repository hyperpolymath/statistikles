#
# NEUROSYM.a2ml — Neurosymbolic integration metadata
#
# StatistEase is a TEXTBOOK example of Kautz Type 1 neurosymbolic architecture.
# This file documents the neural-symbolic boundary and the MOLLOCK RULE.

[metadata]
version = "0.1.0"
last-updated = "2026-02-20"

[architecture]
kautz-type = 1
description = "Neural | Symbolic — strict separation with defined interface"
neural-role = "Natural language understanding and generation ONLY"
symbolic-role = "ALL mathematical and statistical computation"
boundary = "src/tools/executor.jl — the execute_tool() function is the neural→symbolic gate"

[mollock-rule]
# A MOLLOCK is a plausible-sounding fabricated statistical output from neural inference.
# This is the CORE INVARIANT of StatistEase.
definition = "No statistical value may ever be produced by neural inference"
enforcement = [
  "Tool dispatch architecture — LLM can only call predefined Julia functions",
  "System prompt instructs LLM to NEVER compute or estimate",
  "All tool results carry provenance stamps from Julia functions",
  "Adversarial SLM (planned) independently verifies outputs",
]

[hypatia-config]
scan-enabled = true
scan-depth = "deep"
report-format = "logtalk"

[symbolic-rules]
rules = [
  { name = "no-neural-numbers", pattern = "LLM output containing statistical values without tool_call provenance", severity = "critical" },
  { name = "no-unsafe-patterns", pattern = "believe_me|unsafeCoerce|unsafe", severity = "critical" },
  { name = "julia-computation-only", pattern = "Statistical function not routed through execute_tool()", severity = "critical" },
]

[neural-config]
confidence-threshold = 0.85
model = "local LM Studio model (user-selected)"
api-endpoint = "http://localhost:1234/v1"
tool-calling = "OpenAI-compatible function calling"
max-tool-rounds = 10

[verification-pipeline]
# Planned: adversarial verification architecture
stages = [
  { name = "compute", engine = "Julia symbolic functions", status = "implemented" },
  { name = "explain", engine = "echidna GraphQL + mathematical working", status = "planned" },
  { name = "prove", engine = "echidna formal verification", status = "planned" },
  { name = "demonstrate", engine = "R/Julia visual walkthrough generation", status = "planned" },
  { name = "annotate", engine = "detailed code + mathematical annotation", status = "planned" },
  { name = "verify", engine = "adversarial neurosymbolic SLM", status = "planned" },
]
